{
  "appId": "com.busos.app",
  "appName": "BUS OS",
  "webDir": "build",
  "server": {
    "url": "https://allmostcoin.github.io/bus-os",
    "cleartext": true,
    "allowNavigation": [
      "api.anthropic.com",
      "api.groq.com",
      "generativelanguage.googleapis.com",
      "allmostcoin.github.io"
    ]
  },
  "android": {
    "allowMixedContent": true,
    "backgroundColor": "#000000"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 0,
      "backgroundColor": "#000000",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "dark",
      "backgroundColor": "#000000",
      "overlaysWebView": true
    }
  }
}